DATABASE_URL=postgres://user:password@localhost:5432/k9app
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
PORT=3000
# Comma-separated list of allowed CORS origins
# Dev: http://localhost:8081 (Expo), http://localhost:5173 (admin Vite)
# Prod: https://admin.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173

# Stripe — use test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Deep link scheme used by the mobile app (must match app.json scheme)
APP_SCHEME=k9app
