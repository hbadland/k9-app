DATABASE_URL=postgres://user:password@localhost:5432/k9app
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
PORT=3000

# Comma-separated list of allowed CORS origins
# Dev: http://localhost:8081 (Expo), http://localhost:5173 (admin Vite)
# Prod: https://admin.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173

# Stripe — use test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Deep link scheme used by the mobile app (must match app.json scheme)
APP_SCHEME=k9app

# Google OAuth — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# Apple Sign-In — bundle ID of the iOS app
APPLE_BUNDLE_ID=com.batterseak9.app

# Resend — transactional email — https://resend.com/
RESEND_API_KEY=
EMAIL_FROM=Battersea K9 <noreply@batterseak9.com>

# Cloudflare R2 — image/photo storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=k9-uploads
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Sentry — error monitoring — https://sentry.io/
SENTRY_DSN=

# GPS location simulator — set to 'true' for local dev only, never in production
USE_SIMULATOR=false
