{
  "name": "k9-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "kill": "lsof -ti :3000 | xargs kill -9 && echo 'Port 3000 freed'",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "psql $DATABASE_URL -f migrations/001_init.sql && psql $DATABASE_URL -f migrations/002_dog_details.sql && psql $DATABASE_URL -f migrations/003_bookings.sql && psql $DATABASE_URL -f migrations/004_payments.sql && psql $DATABASE_URL -f migrations/005_oauth.sql && psql $DATABASE_URL -f migrations/006_locations.sql"
  },
  "dependencies": {
    "apple-signin-auth": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "socket.io": "^4.8.1",
    "stripe": "^20.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.11.6",
    "@types/react": "~19.1.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
