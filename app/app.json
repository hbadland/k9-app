{
  "expo": {
    "name": "Battersea K9",
    "slug": "k9-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "k9app",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.batterseak9.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Used to upload your profile and dog photos.",
        "NSCameraUsageDescription": "Used to take photos during walks.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.batterseak9.app",
      "adaptiveIcon": {
        "backgroundColor": "#0E0D0B"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to upload your profile and dog photos.",
          "cameraPermission": "Used to take photos during walks."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C9A84C",
          "sounds": []
        }
      ],
      "@sentry/react-native"
    ]
  }
}
